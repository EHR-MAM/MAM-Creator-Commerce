# Copy this to .env and fill in real values — never commit .env
APP_NAME=EHR Creator Commerce Platform
ENVIRONMENT=development
DEBUG=True

# Supabase / PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres.pmkvzwgizpropwjgpopp:[DB_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://pmkvzwgizpropwjgpopp.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_THIS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Commission rates
DEFAULT_CREATOR_COMMISSION_RATE=0.18
DEFAULT_PLATFORM_COMMISSION_RATE=0.12

# Frontend URL (used for tracking link redirects)
